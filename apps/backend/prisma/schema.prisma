generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  lessonProgresses LessonProgress[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Unit {
  id      String   @id @default(uuid())
  title   String
  order   Int
  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id     String @id @default(uuid())
  unitId String
  title  String
  order  Int

  unit       Unit             @relation(fields: [unitId], references: [id])
  vocabulary Vocabulary[]
  kanji      Kanji[]
  grammar    GrammarPoint?
  progresses LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
}

model Vocabulary {
  id       String @id @default(uuid())
  lessonId String

  jp      String
  romaji  String
  meaning String
  example String

  audioUrl String?
  imageUrl String?

  lesson Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model Kanji {
  id       String @id @default(uuid())
  lessonId String

  character String
  meanings  String[]
  onyomi    String[]
  kunyomi   String[]
  examples  String[]

  strokeOrderUrl String?

  lesson Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model GrammarPoint {
  id       String @id @default(uuid())
  lessonId String @unique

  title       String
  explanation String
  pattern     String
  examples    String[]
  audioUrls   String[]

  lesson Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model LessonProgress {
  id       String @id @default(uuid())
  userId   String
  lessonId String

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
}
